# ============================================================
# Poly CopyBot by Super Sauna Club — Einstellungen
# Kopiere diese Datei: cp settings.example.env settings.env
# Secrets (Keys, Passwoerter) gehoeren in secrets.env!
# ============================================================

# --- Gefolgte Trader ---
# Format: Name:WalletAdresse,Name:WalletAdresse
# Finde Trader auf polymarket.com/leaderboard
FOLLOWED_TRADERS=Jargs:0xf1649daae29c44bdb406a4dbb7f1748eac398fa4,xsaghav:0xdbb36e465641957d32376f0e5d32a1f725ce76a9,sovereign2013:0xee613b3fc183ee44f9da9c05f53e2da107e3debf,KING7777777:0xad72ffe37df00548959c2f86f0333e7c958e4f5e,fsavhlc:0x40cfb29411d29f4fa0908f2a121297042cccd21d

# --- Kern ---
LIVE_MODE=true              # false = Paper-Trading (kein Geld), true = Echtgeld
STARTING_BALANCE=320        # Einzahlung in Dollar (fuer Gewinn/Verlust-Berechnung)
COPY_SCAN_INTERVAL=5        # Sekunden zwischen Scans

# --- Wettgroesse ---
# Einsatz skaliert proportional mit der Ueberzeugung des Traders
# Trader setzt 3x seinen Durchschnitt → wir setzen 3x unsere Basis (max RATIO_MAX)
BET_SIZE_PCT=0.04           # Basis: 4% vom Portfolio pro Trade
MAX_POSITION_SIZE=30        # Max $30 pro einzelne Position
MIN_TRADE_SIZE=1.0          # Min $1 pro Trade
RATIO_MIN=0.2               # Min Conviction-Multiplikator (kleiner Trader-Einsatz → 0.2x)
RATIO_MAX=3.0               # Max Conviction-Multiplikator (grosser Trader-Einsatz → 3.0x)
BET_SIZE_BASIS=cash         # "cash" = nur Wallet, "portfolio" = Wallet + Positionen
# Pro-Trader Basis-Einsatz: beste Trader bekommen groessere Wetten
# Ueberschreibt BET_SIZE_PCT pro Trader. Conviction-Logik gilt trotzdem zusaetzlich.
BET_SIZE_MAP=KING7777777:0.08,xsaghav:0.05,sovereign2013:0.02,Jargs:0.02,fsavhlc:0.02

# --- Preis-Signal-Multiplikatoren ---
# Wie stark der Einsatz basierend auf dem Preis skaliert wird
# Edge = Distanz von 50c (z.B. 20c → edge=0.30, 40c → edge=0.10)
PRICE_EDGE_HIGH=0.30        # Ab dieser Edge → starkes Signal (20c oder 80c)
PRICE_MULT_HIGH=1.50        # Multiplikator fuer starkes Signal (1.5x)
PRICE_EDGE_MED=0.15         # Ab dieser Edge → normales Signal (35c oder 65c)
PRICE_MULT_MED=1.00         # Multiplikator fuer normales Signal (1.0x)
PRICE_MULT_LOW=0.60         # Multiplikator fuer schwaches Signal nahe 50c (0.6x)
DEFAULT_AVG_TRADER_SIZE=10.0  # Fallback Durchschnittswette wenn keine Daten
# Pro-Trader Durchschnittswette (fuer Conviction-Ratio). Basierend auf ihren letzten Trades.
AVG_TRADER_SIZE_MAP=xsaghav:25,sovereign2013:1400,KING7777777:20,fsavhlc:50,Jargs:20

# --- Cash-Management ---
CASH_FLOOR=0                # Unter diesem Betrag nicht mehr kaufen (0=aus)
CASH_RECOVERY=6             # Cash muss um $6 ueber Floor steigen bevor wieder gekauft wird
SAVE_POINT_STEP=1.0         # Floor steigt um $1 pro Recovery-Zyklus
CASH_RESERVE=0              # Dollar die NIEMALS fuer Wetten verwendet werden
MAX_OPEN_POSITIONS=100      # Max gleichzeitig offene Positionen
MAX_EXPOSURE_PER_TRADER=0.33  # Standard: max 33% vom Portfolio pro Trader
# Pro-Trader Exposure: bessere Trader bekommen mehr Budget
TRADER_EXPOSURE_MAP=KING7777777:0.65,xsaghav:0.10,sovereign2013:0.02,Jargs:0.02,fsavhlc:0.02

# --- Trade-Filter ---
MIN_TRADER_USD=5            # Trader muss min $5 setzen damit kopiert wird
# Pro-Trader: nur Sovereigns grosse Conviction-Trades, xsaghav sensitiver
MIN_TRADER_USD_MAP=sovereign2013:750,KING7777777:10,xsaghav:15,fsavhlc:15,Jargs:10
MIN_ENTRY_PRICE=0.08        # Unter 8c nicht kaufen
MIN_ENTRY_PRICE_MAP=sovereign2013:0.40  # Sovereign nur ab 40c
MAX_ENTRY_PRICE=0.85        # Ueber 85c nicht kaufen
MAX_ENTRY_PRICE_MAP=sovereign2013:0.75,KING7777777:0.85  # Sovereign max 75c, KING bis 85c
MAX_SPREAD=0.05             # Max 5% Bid/Ask-Spread
MAX_COPIES_PER_MARKET=1     # 1 Kopie pro Markt (kein Doppelkauf)
MAX_FEE_BPS=0               # Max Fee in BPS (0=aus, 500=skip >5% Fee). Esports hat 10% (1000bps)!
# Pro-Trader Kategorie-Blacklist: blockiert bestimmte Sportarten/Kategorien pro Trader
# Format: trader:kat1|kat2,trader:kat1 — Kategorien: nba,mlb,nhl,nfl,tennis,soccer,cs,lol,valorant,dota,geopolitics,cricket
# sovereign2013 verliert massiv bei Tennis (-$13K Norrie) und MLB (-$16K KC Royals)
CATEGORY_BLACKLIST_MAP=xsaghav:cs|valorant|lol,sovereign2013:nba|nfl|nhl|mlb|tennis|soccer|cricket|geopolitics|spread|o/u,fsavhlc:geopolitics|politics|other,Jargs:nba|nfl|nhl|mlb|tennis|soccer|cricket|geopolitics
# Min Conviction-Ratio: nur Trades kopieren wo der Trader ueberdurchschnittlich setzt
# ratio = trader_bet / trader_avg — bei 1.5 muss der Trader 50% mehr als normal setzen
# Filtert Arb-Noise und Test-Trades. Sovereign setzt normal $1400 — mit 1.5 nur ab $2100
MIN_CONVICTION_RATIO=0                              # Global default (0=aus)
MIN_CONVICTION_RATIO_MAP=sovereign2013:1.5           # Sovereign: nur echte Conviction-Bets
ENTRY_TRADE_SEC=300         # Trades aelter als 5 Minuten ignorieren
MAX_HOURS_BEFORE_EVENT=2    # Erst 2 Stunden vor Event kaufen (0=sofort)
EVENT_WAIT_MIN_CASH=0       # 0=immer warten, 100=nur warten wenn Cash < $100
EVENT_WAIT_MAX_SECS=14400   # Gequeute Trades max 4 Stunden aufheben
# Max Preis-Drift bei Ausfuehrung von gequeuten Trades
QUEUE_DRIFT_LOTTERY=0.30    # <20c: max 30% Drift
QUEUE_DRIFT_UNDERDOG=0.40   # 20-40c: max 40% Drift
QUEUE_DRIFT_COINFLIP=0.03   # 40-60c: max 3% Drift
QUEUE_DRIFT_FAVORITE=0.05   # 60-85c: max 5% Drift
MAX_PER_EVENT=15            # Max $15 pro Event/Spiel
MAX_PER_MATCH=15            # Max $15 ueber zusammengehoerende Maerkte (Map1+Map2+BO3)
NO_REBUY_MINUTES=120        # Sperre nach Verkauf fuer selben Markt (120=2h Sperre, 0=aus)

# --- Entry-Mechanik ---
ENTRY_SLIPPAGE=0.03         # Aufschlag auf Entry-Preis fuer realistisches Sizing (0.03=3c)
MAX_ENTRY_PRICE_CAP=0.97    # Absolutes Maximum nach Slippage
TRADE_SEC_FROM_RESOLVE=120  # Nicht mehr kaufen innerhalb 2 Min vor Markt-Schluss

# --- Hedge-Erkennung ---
# Wartet X Sekunden bevor kopiert wird. Kauft Trader Gegenseite → beides uebersprungen
HEDGE_WAIT_SECS=60          # Standard-Wartezeit
HEDGE_WAIT_TRADERS=xsaghav:60,sovereign2013:60,KING7777777:60,fsavhlc:60,Jargs:60

# --- Pending-Buy-Queue ---
# Trades unter Preis-Schwellenwert warten lassen (Standard: aus)
BUY_THRESHOLD=0.0           # Unter diesem Preis warten (0=aus)
PENDING_BUY_MIN_SECS=210    # Mindestens 3.5 Minuten warten
PENDING_BUY_MAX_SECS=900    # Nach 15 Minuten verwerfen

# --- Scan-Throttling ---
MAX_TRADES_PER_SCAN=3       # Max neue Trades pro 5-Sekunden-Scan
RECENT_TRADES_LIMIT=50      # Trades pro Wallet pro Scan abrufen

# --- Risiko-Management ---
# Alles standardmaessig aus (0 = deaktiviert)
MAX_DAILY_LOSS=0            # Trading stoppt bei $X Tagesverlust (0=aus)
MAX_DAILY_TRADES=0          # Max neue Trades pro Tag (0=aus)
STOP_LOSS_PCT=0             # Auto-Verkauf bei X% Verlust (0=aus, 0.50=50%)
TAKE_PROFIT_PCT=2.0         # Auto-Verkauf bei 200% Gewinn
TAKE_PROFIT_MAP=xsaghav:9.0  # xsaghav: 900% TP (8c→80c)
AUTO_SELL_PRICE=0.96        # Gewonnene Positionen ab 96c verkaufen
AUTO_CLOSE_WON_PRICE=0.99   # Ab 99c als gewonnen markieren
AUTO_CLOSE_LOST_PRICE=0.01  # Unter 1c als verloren markieren

# --- Order-Ausfuehrung ---
BUY_SLIPPAGE_LEVELS=0.02,0.05,0.08   # Kauf-Retry: +2c, +5c, +8c (niedriger = weniger Drag)
SELL_SLIPPAGE_LEVELS=0.01,0.03,0.05  # Verkauf-Retry: -1c, -3c, -5c
DELAYED_BUY_VERIFY_SECS=8   # Wartezeit fuer Delayed-Buy-Verifizierung
DELAYED_SELL_VERIFY_SECS=6  # Wartezeit fuer Delayed-Sell-Verifizierung
SELL_VERIFY_THRESHOLD=0.05  # Max Anteil verbleibender Shares (0.05 = 95% muessen verkauft sein)

# --- Fill-Verifizierung ---
FILL_VERIFY_DELAY_SECS=2    # Sekunden nach Kauf bevor Fill geprueft wird
MIN_FILL_AMOUNT=0.10        # Min USDC-Aenderung fuer gueltigen Fill

# --- Position-Tracking ---
MIN_POSITION_SIZE_FILTER=0.50  # Min Positionsgroesse fuer Scans
MISS_COUNT_TO_CLOSE=180     # Stale Positionen nach 180 Misses schliessen (0=aus)
RECENTLY_CLOSED_SECS=600    # Kuerzlich geschlossene Trades 10 Min cachen

# --- Feature-Schalter ---
COPY_SELLS=true             # Verkaeufe der Trader kopieren?
POSITION_DIFF_ENABLED=true  # Position-Diff Fallback-Scan?
IDLE_REPLACE_ENABLED=false  # Inaktive Trader automatisch ersetzen?
IDLE_TRIGGER_SECS=1200      # Ab 20 Min Inaktivitaet ersetzen
IDLE_REPLACE_COOLDOWN=1800  # 30 Min Cooldown nach Ersetzung

# --- Circuit Breaker ---
CB_THRESHOLD=8              # Nach 8 API-Fehlern: Pause
CB_PAUSE_SECS=60            # 60 Sekunden Pause

# --- API-Tuning ---
API_TIMEOUT=10              # Allgemeiner Request-Timeout (Sekunden)
API_MAX_RETRIES=3           # Wiederholungsversuche pro Request
GAMMA_API_TIMEOUT=5         # Gamma API Timeout fuer Event-Abfragen
DATA_API_TIMEOUT=15         # Data API Timeout fuer Positionen/Trades
WS_RECONNECT_SECS=10       # WebSocket Reconnect-Verzoegerung

# --- Live-Preis-Validierung ---
LIVE_PRICE_MIN=0.05         # Min Live-Preis um akzeptiert zu werden
LIVE_PRICE_MAX_DEVIATION=0.50  # Max 50% Abweichung vom Trader-Preis

# --- Dashboard ---
DASHBOARD_PORT=8090
DASHBOARD_HOST=0.0.0.0
