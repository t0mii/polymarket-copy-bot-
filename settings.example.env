# ============================================================
# Poly CopyBot by Super Sauna Club — Settings
# Copy this to settings.env — Secrets go in secrets.env (see secrets.example.env)
# ============================================================

# --- Followed Traders ---
# Format: Name:Address,Name:Address
# Find profitable traders on polymarket.com/leaderboard
FOLLOWED_TRADERS=Jargs:0xf1649daae29c44bdb406a4dbb7f1748eac398fa4,xsaghav:0xdbb36e465641957d32376f0e5d32a1f725ce76a9,sovereign2013:0xee613b3fc183ee44f9da9c05f53e2da107e3debf,KING7777777:0xad72ffe37df00548959c2f86f0333e7c958e4f5e,fsavhlc:0x40cfb29411d29f4fa0908f2a121297042cccd21d

# --- Core ---
LIVE_MODE=true              # false = paper trading, true = real money
STARTING_BALANCE=320        # Your deposit amount (for P&L calculation)
COPY_SCAN_INTERVAL=5        # Seconds between trader scans

# --- Position Sizing ---
# Bet size scales proportionally with trader's conviction
# If trader bets 3x their average -> we bet 3x our base (capped at RATIO_MAX)
BET_SIZE_PCT=0.05           # Base: 5% of portfolio per trade (~$15 at $300)
MAX_POSITION_SIZE=30        # Max $ per single position
MIN_TRADE_SIZE=1.0          # Min $ to execute a trade
RATIO_MIN=0.2               # Min conviction multiplier (small trader bet -> 0.2x base)
RATIO_MAX=3.0               # Max conviction multiplier (huge trader bet -> 3x base)
BET_SIZE_BASIS=cash         # "cash" = size from wallet only, "portfolio" = wallet + positions
# Per-trader bet size: give your best traders bigger bets, reduce weaker ones
# Overrides BET_SIZE_PCT per trader. Conviction logic (ratio, price mult) still applies on top.
# Example at $300 wallet: xsaghav 8%=$24 base, sovereign 3%=$9 base, Jargs 5%=$15 base
BET_SIZE_MAP=xsaghav:0.07,KING7777777:0.03,fsavhlc:0.04,Jargs:0.02

# --- Position Sizing: Price Signal Multipliers ---
# How much to scale bet based on how far price is from 50c
# Edge = distance from 50c (e.g. 20c -> edge=0.30, 40c -> edge=0.10)
PRICE_EDGE_HIGH=0.30        # Edge threshold for strong signal (20c or 80c)
PRICE_MULT_HIGH=1.50        # Multiplier for strong signal (1.5x)
PRICE_EDGE_MED=0.15         # Edge threshold for normal signal (35c or 65c)
PRICE_MULT_MED=1.00         # Multiplier for normal signal (1.0x)
PRICE_MULT_LOW=0.60         # Multiplier for weak signal near 50c (0.6x)
DEFAULT_AVG_TRADER_SIZE=10.0  # Fallback avg trade size when no data

# --- Cash Management ---
CASH_FLOOR=0                # Stop buying below this cash level
CASH_RECOVERY=6             # Must recover this much above floor before resuming
SAVE_POINT_STEP=1.0         # Floor increases by this amount per recovery cycle
CASH_RESERVE=0              # Dollars permanently reserved (never used for betting)
MAX_OPEN_POSITIONS=100      # Max simultaneous open positions
MAX_EXPOSURE_PER_TRADER=0.33  # Default max % of portfolio per trader
# Per-trader exposure: higher % for better performers
TRADER_EXPOSURE_MAP=xsaghav:0.65,sovereign2013:0.40,Jargs:0.25,KING7777777:0.30,fsavhlc:0.20

# --- Trade Filters ---
MIN_TRADER_USD=5            # Only copy trades where trader spends $5+
# Per-trader override: only copy sovereign's big conviction trades, keep xsaghav sensitive
MIN_TRADER_USD_MAP=sovereign2013:750,KING7777777:10,fsavhlc:15
MIN_ENTRY_PRICE=0.08        # Skip trash below 8c (xsaghav's lottery bets at 8-14c are 100% WR)
MIN_ENTRY_PRICE_MAP=sovereign2013:0.40  # Sovereign only 40c+ (filters arb legs)
MAX_ENTRY_PRICE=0.85        # Skip overpriced bets above 85c
MAX_ENTRY_PRICE_MAP=sovereign2013:0.75  # Sovereign max 75c (his sweet spot is 45-75c)
MAX_SPREAD=0.05             # Max bid/ask spread tolerance (5%)
MAX_COPIES_PER_MARKET=1     # 1 copy per market (no doubling up)
ENTRY_TRADE_SEC=300         # Max trade age to copy (5 minutes)
MAX_HOURS_BEFORE_EVENT=2    # Queue trades if event > 2 hours away (0=disabled)
EVENT_WAIT_MIN_CASH=0       # 0=always queue distant events, 100=only queue when cash < $100
# Max price drift when executing queued trades (skip if price moved too much)
# Based on historical data: underdog bets tolerate drift, coinflips don't
QUEUE_DRIFT_LOTTERY=0.30    # <20c entry: max 30% drift (e.g. 15c->19c OK, 15c->20c skip)
QUEUE_DRIFT_UNDERDOG=0.40   # 20-40c: max 40% drift (e.g. 30c->42c OK, 30c->43c skip)
QUEUE_DRIFT_COINFLIP=0.03   # 40-60c: max 3% drift (e.g. 50c->51c OK, 50c->52c skip)
QUEUE_DRIFT_FAVORITE=0.05   # 60-85c: max 5% drift (e.g. 70c->73c OK, 70c->74c skip)
MAX_PER_EVENT=15            # Max $15 per event/game (prevents 5 bets on same match)
NO_REBUY_MINUTES=0          # Block re-entry after close (0=disabled)

# --- Entry Mechanics ---
ENTRY_SLIPPAGE=0.0          # Added to entry price (e.g. 0.01 = 1c buffer)
MAX_ENTRY_PRICE_CAP=0.97    # Hard ceiling after slippage applied
TRADE_SEC_FROM_RESOLVE=120  # Stop buying within 2 min of market close

# --- Hedge Detection ---
# Waits X seconds before copying. If trader buys opposite side -> skip both (hedge)
HEDGE_WAIT_SECS=60          # Default wait time
HEDGE_WAIT_TRADERS=xsaghav:60,sovereign2013:60,KING7777777:60,fsavhlc:60  # Per-trader config

# --- Pending Buy Queue ---
# Queue trades below BUY_THRESHOLD and wait for price confirmation
BUY_THRESHOLD=0.0           # Price threshold (0=disabled, e.g. 0.20=queue below 20c)
PENDING_BUY_MIN_SECS=210    # Min wait before firing queued trade
PENDING_BUY_MAX_SECS=900    # Max wait before discarding

# --- Scan Throttling ---
MAX_TRADES_PER_SCAN=3       # Max new trades per 5-second scan cycle
RECENT_TRADES_LIMIT=50      # Trades to fetch per wallet per scan

# --- Risk Management ---
# All disabled by default (0 = off). Enable by setting a value > 0.
MAX_DAILY_LOSS=0            # Stop trading if daily loss exceeds $X (0=disabled)
MAX_DAILY_TRADES=0          # Max new trades per day (0=disabled)
STOP_LOSS_PCT=0             # Auto-sell at X% loss (0=disabled, e.g. 0.50=50% loss)
TAKE_PROFIT_PCT=2.0         # Auto-sell at 200% gain (0=disabled)
TAKE_PROFIT_MAP=xsaghav:9.0  # Per-trader TP override (xsaghav: 900% = 8c->80c)
AUTO_SELL_PRICE=0.96        # Sell won positions above this price (recycle capital)
AUTO_CLOSE_WON_PRICE=0.99   # Mark as won above this (waiting for redeem)
AUTO_CLOSE_LOST_PRICE=0.01   # Mark as lost below this (position dead)

# --- Feature Toggles ---
COPY_SELLS=true             # Copy sell signals from traders (false=hold until resolve)
POSITION_DIFF_ENABLED=true  # Enable position-diff fallback scan
IDLE_REPLACE_ENABLED=false  # Auto-replace inactive traders from leaderboard
IDLE_TRIGGER_SECS=1200      # Seconds of inactivity before replacement (20 min)
IDLE_REPLACE_COOLDOWN=1800  # Cooldown after replacing a trader (30 min)

# --- Circuit Breaker ---
CB_THRESHOLD=8              # Consecutive API failures to trip breaker
CB_PAUSE_SECS=60            # Seconds to pause when breaker trips

# --- API Tuning ---
API_TIMEOUT=10              # GET request timeout (seconds)
API_MAX_RETRIES=3           # Retry attempts per request

# --- Live Price Validation ---
LIVE_PRICE_MIN=0.05         # Min live price to accept (below = use trader price)
LIVE_PRICE_MAX_DEVIATION=0.50  # Max % deviation from trader price (0.50=50%)

# --- Fill Verification ---
FILL_VERIFY_DELAY_SECS=2    # Seconds to wait after buy before checking fill
MIN_FILL_AMOUNT=0.10        # Min fill amount to count as valid ($)

# --- Position Tracking ---
MIN_POSITION_SIZE_FILTER=0.50  # Min shares to include in diff scan / baseline
MISS_COUNT_TO_CLOSE=180     # Consecutive misses before closing stale position

# --- Dashboard ---
DASHBOARD_PORT=8090
DASHBOARD_HOST=0.0.0.0
