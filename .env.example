# ============================================================
# Polymarket Copy Trade Bot — Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Polymarket CLOB API (REQUIRED for live trading) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=

# --- AI APIs (OPTIONAL — for wallet analysis) ---
GROQ_API_KEY=
ZAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Builder API (REQUIRED for auto-redeem) ---
# Get from polymarket.com/settings -> Builder
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# --- Massive.com Market Data (OPTIONAL) ---
MASSIVE_API_KEY=

# --- Trading Parameters ---
LIVE_MODE=false
STARTING_BALANCE=200
MAX_POSITION_SIZE=5
MIN_TRADE_SIZE=1.0
CASH_FLOOR=0
CASH_RECOVERY=6
MAX_OPEN_POSITIONS=100
MAX_SPREAD=0.05
ENTRY_TRADE_SEC=300
COPY_SCAN_INTERVAL=5
BET_SIZE_PCT=0.02

# --- RN1 Smart Filter ---
MIN_TRADER_USD=15
MIN_ENTRY_PRICE=0.05
MAX_ENTRY_PRICE=0.92
MAX_COPIES_PER_MARKET=2

# --- Dashboard ---
DASHBOARD_PORT=8090
DASHBOARD_HOST=0.0.0.0
DASHBOARD_SECRET=changeme
