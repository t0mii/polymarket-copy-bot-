# ============================================================
# Poly CopyBot by Super Sauna Club — Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Polymarket CLOB API (REQUIRED for live trading) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=

# --- Builder API (REQUIRED for auto-redeem of won positions) ---
# Get from polymarket.com/settings -> Builder
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# --- Followed Traders ---
# Format: Name:Address,Name:Address
# Find profitable traders on polymarket.com/leaderboard
FOLLOWED_TRADERS=Jargs:0xf1649daae27f3dd24802e331c5528340a1ebb091,xsaghav:0xdbb36e465641957d32c5daa30d575e3038eccb83,sovereign2013:0xee613b3fc183ee44f9da9c05f53e2da107e3debf

# --- Hedge Detection ---
# Per-trader wait time in seconds to detect if trader buys both sides
# Format: name:seconds,name:seconds — set to 0 to disable
HEDGE_WAIT_SECS=60
HEDGE_WAIT_TRADERS=xsaghav:60,sovereign2013:60

# --- Core ---
LIVE_MODE=false
STARTING_BALANCE=320
COPY_SCAN_INTERVAL=5

# --- Position Sizing ---
# Bet size scales proportionally with trader's conviction
# If trader bets 3x their average → we bet 3x our base
BET_SIZE_PCT=0.05           # Base: 5% of portfolio per trade (~$15 at $300)
MAX_POSITION_SIZE=30        # Max $ per single position
MIN_TRADE_SIZE=1.0          # Min $ to execute a trade
RATIO_MIN=0.2               # Min conviction multiplier (small trader bet → 0.2x base)
RATIO_MAX=3.0               # Max conviction multiplier (huge trader bet → 3x base)

# --- Cash Management ---
CASH_FLOOR=0                # Stop buying below this cash level
CASH_RECOVERY=6             # Recovery threshold
MAX_OPEN_POSITIONS=100
MAX_EXPOSURE_PER_TRADER=0.33  # Default max % per trader
# Per-trader override: "name:pct,name:pct" — higher % for better performers
TRADER_EXPOSURE_MAP=sovereign2013:0.50,xsaghav:0.50,Jargs:0.50

# --- Trade Filters ---
MIN_TRADER_USD=3            # Only copy trades where trader spends $X+
MIN_ENTRY_PRICE=0.05        # Skip trash farming below 5c
MAX_ENTRY_PRICE=0.92        # Skip hedges above 92c
MAX_SPREAD=0.05             # Max bid/ask spread
MAX_COPIES_PER_MARKET=1     # 1 copy per market (no doubling up)
ENTRY_TRADE_SEC=300         # Max trade age to copy (seconds)

# --- Dashboard ---
DASHBOARD_PORT=8090
DASHBOARD_HOST=0.0.0.0
DASHBOARD_SECRET=changeme   # Required for follow/unfollow API endpoints
