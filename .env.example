# ============================================================
# Poly CopyBot by Super Sauna Club — Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Polymarket CLOB API (REQUIRED for live trading) ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=

# --- Builder API (REQUIRED for auto-redeem) ---
# Get from polymarket.com/settings -> Builder
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# --- Followed Traders ---
# Format: Name:Address,Name:Address
# Example traders (esports + sports conviction traders):
FOLLOWED_TRADERS=Jargs:0xf1649daae27f3dd24802e331c5528340a1ebb091,xsaghav:0xdbb36e465641957d32c5daa30d575e3038eccb83

# --- Hedge Wait (per trader, seconds to wait for hedge detection) ---
HEDGE_WAIT_TRADERS=xsaghav:30

# --- Trading Parameters ---
LIVE_MODE=false
STARTING_BALANCE=320
BET_SIZE_PCT=0.20
MAX_POSITION_SIZE=15
MIN_TRADE_SIZE=1.0
MIN_TRADER_USD=50
CASH_FLOOR=0
MAX_OPEN_POSITIONS=100
MAX_SPREAD=0.05
COPY_SCAN_INTERVAL=5

# --- Entry Filters ---
MIN_ENTRY_PRICE=0.05
MAX_ENTRY_PRICE=0.92
MAX_COPIES_PER_MARKET=2

# --- Performance Report ---
REPORT_INTERVAL_HOURS=0

# --- Dashboard ---
DASHBOARD_PORT=8090
DASHBOARD_HOST=0.0.0.0
DASHBOARD_SECRET=changeme
